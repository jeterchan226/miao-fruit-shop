# 連線到本機 PostgreSQL(docker-compose 的 db 服務或本機安裝)
DATABASE_URL=postgresql+asyncpg://miao:miao@localhost:5432/miao
# JWT 簽章密鑰(正式環境務必改成隨機長字串)
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# 逗號分隔的允許來源
CORS_ORIGINS=http://localhost:8080
# GCS 圖片儲存（選填，未設定時圖片 API 回傳 503）
GCS_BUCKET_NAME=miao-bucket
GCS_CREDENTIALS_B64=<base64 encoded service account JSON>
