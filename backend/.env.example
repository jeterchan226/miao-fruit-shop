# 連線到本機 PostgreSQL(docker-compose 的 db 服務或本機安裝)
DATABASE_URL=postgresql+asyncpg://miao:miao@localhost:5432/miao
# Cloud Run 可改用拆開式 DB 設定，DB_PASSWORD 建議掛 Secret Manager
# DB_USER=ecommerce_user
# DB_PASSWORD=<cloud sql password>
# DB_NAME=ecommerce
# DB_HOST=/cloudsql/cy-ecommerce-v1:asia-east1:cy-ecommerce-db
# DB_PORT=5432
# JWT 簽章密鑰(正式環境務必改成隨機長字串)
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# 逗號分隔的允許來源（本地測試 + 正式網址，依實際前端網址調整）
CORS_ORIGINS=http://localhost:8080,https://your-app.vercel.app
# GCS 圖片儲存（選填，未設定時圖片 API 回傳 503）
GCS_BUCKET_NAME=miao-bucket
GCS_CREDENTIALS_B64=<base64 encoded service account JSON>
# LINE 官方帳號 Messaging API（選填，未設定時不會推送訂單通知）
LINE_CHANNEL_ACCESS_TOKEN=<line messaging api channel access token>
# LINE webhook 簽章驗證用（LINE Developers Console → Channel secret）
LINE_CHANNEL_SECRET=<line channel secret>
# Rich Menu「立即訂購」開啟的 LIFF App ID（同前端 VITE_MIAO_LIFF_ID）
LINE_LIFF_ID=1234567890-AbcdEfgh
